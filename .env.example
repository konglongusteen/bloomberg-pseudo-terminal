# Network Hosting Configurations
PORT=3000

# JSON Web Token Secret (Change to a long random security string)
JWT_SECRET=SUPER_SECRET_JWT_SIGNING_STRING_123456

# Institutional API Keys (Leave blank if you wish to run the Terminal in offline high-fidelity simulation mode)
FINNHUB_API_KEY=your_finnhub_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here